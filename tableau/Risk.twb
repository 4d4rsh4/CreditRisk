        </calculation>
      </column>
      <column caption='Calculation3' datatype='real' name='[Calculation_0787318091075588]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='sum([TARGET])/ COUNT([SK_ID_CURR])' />
